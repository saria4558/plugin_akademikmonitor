<div class="akademikmonitor">
  <div class="am-wrap">
    {{> local_akademikmonitor/sidebar }}

    <div class="am-content">
      <div class="am-breadcrumb">/ Manajemen Kelas / Histori</div>

      <div class="am-page-heading" style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
          <h1 class="am-h1">Histori Kelas</h1>
          <div class="am-sub">Histori rombel {{kelas_nama}} jurusan {{jurusan_nama}} berdasarkan tahun ajaran.</div>
        </div>
        <a href="{{back_url}}" class="am-btn am-btn-secondary">Kembali</a>
      </div>

      <div class="am-card">
        <div class="am-table-wrap">
          <table class="am-table">
            <thead>
              <tr>
                <th>No</th>
                <th>Nama Kelas</th>
                <th>Jurusan</th>
                <th>Tingkat</th>
                <th>Tahun Ajaran</th>
                <th>Wali Kelas</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {{#items}}
              <tr>
                <td data-label="No">{{no}}</td>
                <td data-label="Nama Kelas"><strong>{{nama}}</strong></td>
                <td data-label="Jurusan">{{jurusan}}</td>
                <td data-label="Tingkat">{{tingkat}}</td>
                <td data-label="Tahun Ajaran">{{tahun_ajaran}}</td>
                <td data-label="Wali Kelas">{{wali_nama}}</td>
                <td data-label="Status">
                  {{#is_current}}<span class="am-badge am-badge-info">Dipilih</span>{{/is_current}}
                  {{^is_current}}<span class="am-badge">Histori</span>{{/is_current}}
                </td>
              </tr>
              {{/items}}

              {{^items}}
              <tr>
                <td colspan="7" class="am-empty-state" style="text-align:center;padding:24px;">Belum ada histori kelas.</td>
              </tr>
              {{/items}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
